---
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:dc="http://purl.org/dc/elements/1.1/">
  <channel>
    <title>{{ site.title }}</title>
    <link>{{ site.url }}</link>
    <description>Notes on AI, engineering, and building things that matter. AI agent architecture, conversation intelligence, and LLM integration.</description>
    <language>en</language>
    <lastBuildDate>{{ site.posts.first.date | date_to_rfc822 }}</lastBuildDate>
    <atom:link href="{{ site.url }}/feed.xml" rel="self" type="application/rss+xml"/>
{% for post in site.posts %}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <link>{{ post.url | absolute_url }}</link>
      <guid>{{ post.url | absolute_url }}</guid>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      <dc:creator>{{ site.author }}</dc:creator>
      <description>{{ post.description | xml_escape }}</description>
    </item>
{% endfor %}
  </channel>
</rss>
